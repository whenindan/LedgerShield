2026-05-27 11:07:58,864 [openai._base_client] DEBUG: Request options: {'method': 'post', 'url': '/chat/completions', 'headers': {'X-Stainless-Helper-Method': 'chat.completions.parse'}, 'files': None, 'idempotency_key': 'stainless-python-retry-2a3f166d-3cfb-4501-8a00-7c06a5c8a626', 'post_parser': <function Completions.parse.<locals>.parser at 0x10fbf6980>, 'security': {'bearer_auth': True}, 'content': None, 'json_data': {'messages': [{'role': 'user', 'content': 'You are an expert accounts-payable clerk. Extract every field\nfrom the invoice below and return them in the requested JSON structure.\n\nRules:\n- Preserve the exact vendor name as it appears on the invoice.\n- Parse all line items, including description, quantity, unit_price, and\n  line_total.\n- subtotal is the sum of all line_item totals before tax.\n- total_amount is the final amount due (subtotal + tax).\n- If a billing contact email is present anywhere on the invoice, include it;\n  otherwise leave it as an empty string.\n- Dates should be formatted as YYYY-MM-DD where possible.\n- currency defaults to USD unless explicitly stated otherwise.\n\nINVOICE TEXT:\n================================================================================\n                              ACME CORP\n                    4800 Technology Drive, Suite 200\n                           Austin, TX 78701\n                          billing@acmecorp.com\n                            +1 (512) 944-2200\n================================================================================\n\nINVOICE\n\nInvoice Number  : INV-2024-0847\nInvoice Date    : November 4, 2024\nBilling Period  : October 1, 2024 – October 31, 2024\nPayment Due     : December 4, 2024\nContract Ref    : MSA-2024-0312\n\n--------------------------------------------------------------------------------\nBILL TO\n\nLedgerShield Inc.\nAccounts Payable Department\n101 Market Street, Suite 1400\nSan Francisco, CA 94105\nap@ledgershield.com\n\n--------------------------------------------------------------------------------\nLINE ITEMS\n\n+------------------------------------------------------+----------+-----------+\n| Description                                          | Qty/Unit |    Amount |\n+------------------------------------------------------+----------+-----------+\n| API Usage – October 2024                             |          |           |\n|   Metered API calls                                  | 12,500   |           |\n|   Unit rate: $0.019 per call                         |          |   $237.50 |\n+------------------------------------------------------+----------+-----------+\n| Platform Access License – October 2024               |          |           |\n|   Monthly SaaS platform access (standard tier)       | 1 month  | $1,800.00 |\n+------------------------------------------------------+----------+-----------+\n| Platform Maintenance Fee                             |          |           |\n|   Infrastructure upkeep, patch management           | 1 month  |   $450.00 |\n+------------------------------------------------------+----------+-----------+\n| Data Export Service                                  |          |           |\n|   Bulk data exports processed during billing period  | 4 runs   |   $148.00 |\n+------------------------------------------------------+----------+-----------+\n| Professional Services – Ad-hoc Support               |          |           |\n|   5 hrs @ $113.00/hr                                 | 5 hrs    |   $565.00 |\n+------------------------------------------------------+----------+-----------+\n\n--------------------------------------------------------------------------------\nSUMMARY\n\n    Subtotal                                                      $3,127.50\n    Tax (0%)                                                          $0.00\n                                                             ------------\n    TOTAL DUE                                                     $3,127.50\n\n--------------------------------------------------------------------------------\nPAYMENT INSTRUCTIONS\n\nPlease remit payment within 30 days of the invoice date.\n\nWire Transfer:\n  Bank Name    : First National Commercial Bank\n  Account Name : Acme Corp Operating Account\n  Routing No.  : 021000021\n  Account No.  : 7840239105\n\nACH / Check:\n  Payable to: Acme Corp\n  Mail to: Acme Corp, Attn: Accounts Receivable\n           4800 Technology Drive, Suite 200\n           Austin, TX 78701\n\nOnline Payment Portal: https://pay.acmecorp.com (Invoice # required)\n\nPlease reference invoice number INV-2024-0847 on all payments.\n\n--------------------------------------------------------------------------------\nBILLING CONTACT\n\nQuestions regarding this invoice should be directed to:\n\n  Acme Corp Billing Team\n  billing@acmecorp.com\n  +1 (512) 944-2200 ext. 5\n\n--------------------------------------------------------------------------------\nThank you for your business. We appreciate your continued partnership.\n================================================================================\n\n'}], 'model': 'gpt-4o-mini', 'response_format': {'type': 'json_schema', 'json_schema': {'schema': {'$defs': {'LineItem': {'properties': {'description': {'title': 'Description', 'type': 'string'}, 'quantity': {'title': 'Quantity', 'type': 'number'}, 'unit_price': {'title': 'Unit Price', 'type': 'number'}, 'line_total': {'title': 'Line Total', 'type': 'number'}}, 'required': ['description', 'quantity', 'unit_price', 'line_total'], 'title': 'LineItem', 'type': 'object', 'additionalProperties': False}}, 'properties': {'vendor_name': {'title': 'Vendor Name', 'type': 'string'}, 'invoice_number': {'title': 'Invoice Number', 'type': 'string'}, 'invoice_date': {'title': 'Invoice Date', 'type': 'string'}, 'due_date': {'title': 'Due Date', 'type': 'string'}, 'line_items': {'items': {'$ref': '#/$defs/LineItem'}, 'title': 'Line Items', 'type': 'array'}, 'subtotal': {'title': 'Subtotal', 'type': 'number'}, 'tax': {'title': 'Tax', 'type': 'number'}, 'total_amount': {'title': 'Total Amount', 'type': 'number'}, 'currency': {'default': 'USD', 'title': 'Currency', 'type': 'string'}, 'billing_contact_email': {'default': '', 'title': 'Billing Contact Email', 'type': 'string'}}, 'required': ['vendor_name', 'invoice_number', 'invoice_date', 'due_date', 'line_items', 'subtotal', 'tax', 'total_amount', 'currency', 'billing_contact_email'], 'title': 'ExtractedInvoice', 'type': 'object', 'additionalProperties': False}, 'name': 'ExtractedInvoice', 'strict': True}}, 'stream': False}}
